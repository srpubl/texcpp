3:WRITE(PLFILE,ASCII14[1+(TFM[K]MOD 32)]);END;END;END;
{:35}{36:}PROCEDURE OUTOCTAL(K,L:INDEX);VAR A:0..1023;B:0..32;J:0..11;
BEGIN WRITE(PLFILE,' O ');A:=0;B:=0;J:=0;WHILE L>0 DO{37:}BEGIN L:=L-1;
