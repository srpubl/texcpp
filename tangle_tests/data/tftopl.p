{:34}{35:}PROCEDURE OUTBCPL(K:INDEX);VAR L:0..39;
BEGIN WRITE(PLFILE,' ');L:=TFM[K];WHILE L>0 DO BEGIN K:=K+1;L:=L-1;
CASE TFM[K]DIV 32 OF 1:WRITE(PLFILE,ASCII04[1+(TFM[K]MOD 32)]);
